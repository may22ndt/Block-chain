# Set to False if MongoDB is not running and you only want Django commands to start.
AUTO_CREATE_MONGO_INDEXES=True

# Blockchain integration: ChuoiCungUng on Ethereum Sepolia.
# Set BLOCKCHAIN_ENABLED=True only when WEB3_PROVIDER_URL and PRIVATE_KEY are ready.
