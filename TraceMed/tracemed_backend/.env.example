DJANGO_SECRET_KEY=tracemed-local-development-secret-key-change-before-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MongoDB local development
MONGO_URI=mongodb://localhost:27017/tracemed
